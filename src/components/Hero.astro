---
// Terminal Boot Sequence Hero
---

<section id="home" class="hero-section">
  <div class="terminal-hero crt-flicker" role="banner">
    <!-- Matrix rain canvas background -->
    <canvas id="matrixCanvas" class="matrix-canvas" aria-hidden="true"></canvas>

    <!-- Terminal title bar -->
    <div class="terminal-titlebar">
      <span class="glow-cyan">MEUSE24_OS v2.0</span>
      <span class="terminal-dots">
        <span class="dot dot-red"></span>
        <span class="dot dot-amber"></span>
        <span class="dot dot-green"></span>
      </span>
    </div>

    <!-- Terminal content -->
    <div class="terminal-body">

      <!-- Boot sequence lines -->
      <div class="boot-lines">
        <div class="boot-line line-1">
          <span class="glow-green" data-key="hero_boot_1">&gt; SYSTEM BOOT...</span>
          <span class="boot-ok glow-green">[OK]</span>
        </div>
        <div class="boot-line line-2">
          <span class="glow-green" data-key="hero_boot_2">&gt; LOADING MODULES...</span>
          <span class="boot-ok glow-green">[OK]</span>
        </div>
        <div class="boot-line line-3">
          <span class="glow-green" data-key="hero_boot_3">&gt; CONNECTING...</span>
          <span class="boot-ok glow-green">[OK]</span>
        </div>
        <div class="boot-line line-4">
          <span class="glow-green" data-key="hero_boot_4">&gt; LOCATION: AUSTRIA</span>
          <span class="boot-ok glow-green">[OK]</span>
        </div>
      </div>

      <!-- Glitch Title – centered, fills middle space -->
      <div class="hero-title line-5" aria-label="MEUSE24">
        <span class="glitch" data-text="MEUSE24">MEUSE24</span>
      </div>

      <!-- Tagline + CTA pinned to bottom -->
      <div class="bottom-section">
        <div class="tagline line-6">
          <span data-key="hero_tagline">Developer // Austria // Code Architect</span>
        </div>
        <a href="#projects" class="prompt-cta line-7" aria-label="Explore projects">
          <span class="glow-cyan typing-cursor" data-key="hero_prompt">&gt; explore projects</span>
        </a>
      </div>

    </div>
  </div>
</section>

<style>
  /* Hero section – fills viewport below header */
  .hero-section {
    display: flex;
    align-items: stretch;
    justify-content: center;
    min-height: calc(100vh - var(--header-height));
    min-height: calc(100dvh - var(--header-height));
    padding: 0.75rem clamp(0.5rem, 2vw, 1.5rem);
  }

  /* Terminal window – fills available height */
  .terminal-hero {
    width: 100%;
    max-width: min(1440px, 95vw);
    border: 1px solid var(--color-border-bright);
    background: var(--color-surface);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 0 30px rgba(0, 255, 245, 0.05);
    transition: box-shadow 0.3s ease;
    position: relative;
  }

  /* Matrix rain canvas */
  .matrix-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    opacity: 0.18;
  }

  .terminal-hero:hover {
    box-shadow: 0 0 40px rgba(0, 255, 245, 0.1), 0 0 80px rgba(0, 255, 245, 0.03);
  }

  /* Title bar */
  .terminal-titlebar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--color-border-bright);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red   { background: #ff5f57; }
  .dot-amber { background: #ffbd2e; }
  .dot-green { background: #28c840; }

  /* Body – flex column, fills remaining height */
  .terminal-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: clamp(1.25rem, 3vw, 2.5rem) clamp(1rem, 3vw, 2.5rem);
    font-size: clamp(0.8rem, 1.2vw, 0.95rem);
    line-height: 1.8;
    min-height: 0;
    position: relative;
    z-index: 1;
  }

  /* Boot lines – stay at top */
  .boot-lines {
    flex-shrink: 0;
  }

  .boot-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    opacity: 0;
    animation: fade-in 0.4s ease forwards;
  }

  .boot-ok {
    font-weight: 700;
  }

  .line-1 { animation-delay: 0.2s; }
  .line-2 { animation-delay: 0.6s; }
  .line-3 { animation-delay: 1.0s; }
  .line-4 { animation-delay: 1.4s; }
  .line-5 { animation-delay: 1.9s; }
  .line-6 { animation-delay: 2.4s; }
  .line-7 { animation-delay: 2.8s; }

  @keyframes fade-in {
    from { opacity: 0; transform: translateY(4px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Glitch title – grows to fill middle, centered */
  .hero-title {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    animation: fade-in 0.6s ease forwards;
  }

  .glitch {
    font-size: clamp(3.5rem, 10vw, 9rem);
    font-weight: 700;
    color: var(--color-neon-cyan);
    letter-spacing: 0.1em;
    position: relative;
    display: inline-block;
    text-shadow:
      0 0 10px rgba(0, 255, 245, 0.5),
      0 0 40px rgba(0, 255, 245, 0.2);
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0; left: 0;
    width: 100%; height: 100%;
    overflow: hidden;
  }

  .glitch::before {
    color: var(--color-neon-magenta);
    text-shadow: none;
    clip-path: inset(0 0 65% 0);
    animation: glitch-top 3s steps(1) infinite;
  }

  .glitch::after {
    color: var(--color-terminal-green);
    text-shadow: none;
    clip-path: inset(60% 0 0 0);
    animation: glitch-bottom 3.5s steps(1) infinite;
  }

  @keyframes glitch-top {
    0%, 100% { transform: translate(0); }
    2%  { transform: translate(2px, -1px); }
    4%  { transform: translate(-2px, 1px); }
    6%  { transform: translate(0); }
    42% { transform: translate(0); }
    44% { transform: translate(-3px, -1px); }
    46% { transform: translate(0); }
  }

  @keyframes glitch-bottom {
    0%, 100% { transform: translate(0); }
    18% { transform: translate(0); }
    20% { transform: translate(3px, 1px); }
    22% { transform: translate(-1px, -1px); }
    24% { transform: translate(0); }
    62% { transform: translate(0); }
    64% { transform: translate(2px, 0); }
    66% { transform: translate(0); }
  }

  /* Bottom section – tagline + CTA pinned to bottom */
  .bottom-section {
    flex-shrink: 0;
  }

  .tagline {
    color: var(--color-text-dim);
    font-size: clamp(0.8rem, 1.2vw, 1rem);
    margin-bottom: 0.75rem;
    letter-spacing: 0.1em;
    opacity: 0;
    animation: fade-in 0.5s ease forwards;
  }

  .prompt-cta {
    display: inline-block;
    text-decoration: none;
    font-size: clamp(0.85rem, 1.3vw, 1.05rem);
    padding: 0.5rem 0;
    opacity: 0;
    animation: fade-in 0.5s ease forwards;
    transition: opacity 0.2s ease;
  }

  .prompt-cta:hover { opacity: 0.8; }

  .prompt-cta:focus-visible {
    outline: 1px solid var(--color-neon-cyan);
    outline-offset: 4px;
  }
</style>

<script>
  const canvas = document.getElementById('matrixCanvas') as HTMLCanvasElement;
  if (canvas) {
    const ctx = canvas.getContext('2d')!;

    // Detect iOS/Safari for performance adjustments
    const isIOS = /iPad|iPhone|iPod/.test(navigator.userAgent) ||
      (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 1);
    const isSafari = /^((?!chrome|android).)*safari/i.test(navigator.userAgent);
    const isLowPower = isIOS || (isSafari && navigator.maxTouchPoints > 0);

    // Character set — code-focused: braces, operators, hex, fragments of syntax
    const chars =
      '01{}[]()<>=;:./\\|&!?#@$%^~+-*_' +
      'const let var fn async await return if else for while' +
      'ABCDEF0123456789abcdef' +
      '=>!=&&||::>><<' +
      '▪▫▸▹◆◇░▒▓';
    // Split into individual drawing units (single chars from the concatenated string)
    const charArr = chars.split('');
    const fontSize = 14;
    const trailLength = isLowPower ? 14 : 22;

    // Site color palette — each column picks a hue
    const palettes = [
      { head: '#b0ffff', bright: '#ffffff', r: 0, g: 220, b: 245 },   // cyan
      { head: '#b0ffb0', bright: '#e0ffe0', r: 15, g: 235, b: 80 },   // green
      { head: '#ffb0d0', bright: '#ffe0f0', r: 255, g: 80, b: 160 },  // magenta
      { head: '#ffe0a0', bright: '#fff5d0', r: 255, g: 190, b: 40 },  // amber
    ];

    interface Column {
      y: number;
      speed: number;
      accum: number;
      bright: boolean;
      reverse: boolean;     // falls upward
      palette: number;      // index into palettes
      chars: string[];
    }

    let columns: Column[] = [];
    let colCount = 0;

    function randChar(): string {
      return charArr[Math.floor(Math.random() * charArr.length)];
    }

    function makeColumn(startOffscreen = true): Column {
      const maxRow = Math.ceil((canvas.clientHeight || 600) / fontSize);
      const reverse = Math.random() < 0.12; // ~12% fall upward
      return {
        y: reverse
          ? (startOffscreen ? maxRow + Math.random() * 30 : Math.floor(Math.random() * maxRow))
          : (startOffscreen ? Math.random() * -35 : Math.floor(Math.random() * maxRow)),
        speed: 0.2 + Math.random() * 0.6,
        accum: 0,
        bright: Math.random() < 0.06,
        reverse,
        palette: Math.floor(Math.random() * palettes.length),
        chars: Array.from({ length: trailLength }, randChar),
      };
    }

    function resize() {
      const rect = canvas.parentElement!.getBoundingClientRect();
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = rect.width * dpr;
      canvas.height = rect.height * dpr;
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const newCount = Math.floor(rect.width / fontSize);
      while (columns.length < newCount) columns.push(makeColumn(true));
      columns.length = newCount;
      colCount = newCount;
    }

    function draw() {
      const w = canvas.clientWidth;
      const h = canvas.clientHeight;

      ctx.fillStyle = 'rgba(10, 10, 15, 0.1)';
      ctx.fillRect(0, 0, w, h);
      ctx.font = `${fontSize}px monospace`;

      const maxRow = Math.ceil(h / fontSize);

      for (let i = 0; i < colCount; i++) {
        const col = columns[i];
        const pal = palettes[col.palette];
        const x = i * fontSize;
        const dir = col.reverse ? -1 : 1;

        // Advance
        col.accum += col.speed;
        while (col.accum >= 1) {
          col.accum -= 1;
          col.y += dir;
          col.chars.pop();
          col.chars.unshift(randChar());
        }

        // Flicker trail chars
        if (Math.random() < 0.25) {
          const idx = Math.floor(Math.random() * trailLength);
          col.chars[idx] = randChar();
        }

        // Draw trail
        const headY = Math.floor(col.y);
        for (let j = 0; j < trailLength; j++) {
          const row = headY - j * dir;
          if (row < 0 || row > maxRow) continue;
          const py = row * fontSize;

          if (j === 0) {
            // Glowing head
            if (!isLowPower) {
              ctx.shadowColor = col.bright ? pal.bright : pal.head;
              ctx.shadowBlur = col.bright ? 18 : 10;
            }
            ctx.fillStyle = col.bright ? pal.bright : pal.head;
            ctx.fillText(col.chars[j], x, py);
            ctx.shadowBlur = 0;
          } else if (j === 1) {
            ctx.fillStyle = `rgba(${pal.r}, ${pal.g}, ${pal.b}, 0.85)`;
            ctx.fillText(col.chars[j], x, py);
          } else {
            // Fading trail with color
            const fade = 1 - j / trailLength;
            const alpha = fade * fade * 0.55;
            if (alpha < 0.02) continue;

            // Desaturate deeper in the trail
            const desat = j / trailLength;
            const r = Math.floor(pal.r * (1 - desat * 0.5));
            const g = Math.floor(pal.g * (1 - desat * 0.3));
            const b = Math.floor(pal.b * (1 - desat * 0.2));
            ctx.fillStyle = `rgba(${r}, ${g}, ${b}, ${alpha})`;
            ctx.fillText(col.chars[j], x, py);
          }
        }

        // Reset column
        if (col.reverse) {
          if (col.y + trailLength < 0) {
            if (Math.random() > 0.94) columns[i] = makeColumn(true);
          }
        } else {
          if (col.y - trailLength > maxRow) {
            if (Math.random() > 0.94) columns[i] = makeColumn(true);
          }
        }
      }
    }

    resize();
    window.addEventListener('resize', resize);

    const frameInterval = isLowPower ? 50 : 33;
    let lastFrame = 0;
    let running = true;

    function loop(time: number) {
      if (running && time - lastFrame > frameInterval) {
        draw();
        lastFrame = time;
      }
      requestAnimationFrame(loop);
    }
    requestAnimationFrame(loop);

    const observer = new IntersectionObserver(
      (entries) => { running = entries[0].isIntersecting; },
      { threshold: 0 },
    );
    observer.observe(canvas);
  }
</script>
