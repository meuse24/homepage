---
// Terminal Boot Sequence Hero
---

<section id="home" class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="terminal-hero crt-flicker" role="banner">
    <!-- Terminal title bar -->
    <div class="terminal-titlebar">
      <span class="glow-cyan">MEUSE24_OS v2.0</span>
      <span class="terminal-dots">
        <span class="dot dot-red"></span>
        <span class="dot dot-amber"></span>
        <span class="dot dot-green"></span>
      </span>
    </div>

    <!-- Terminal content -->
    <div class="terminal-body">
      <!-- Boot sequence lines -->
      <div class="boot-line line-1">
        <span class="glow-green" data-key="hero_boot_1">&gt; SYSTEM BOOT...</span>
        <span class="boot-ok glow-green">[OK]</span>
      </div>
      <div class="boot-line line-2">
        <span class="glow-green" data-key="hero_boot_2">&gt; LOADING MODULES...</span>
        <span class="boot-ok glow-green">[OK]</span>
      </div>
      <div class="boot-line line-3">
        <span class="glow-green" data-key="hero_boot_3">&gt; CONNECTING...</span>
        <span class="boot-ok glow-green">[OK]</span>
      </div>
      <div class="boot-line line-4">
        <span class="glow-green" data-key="hero_boot_4">&gt; LOCATION: AUSTRIA</span>
        <span class="boot-ok glow-green">[OK]</span>
      </div>

      <!-- Glitch Title -->
      <div class="hero-title line-5" aria-label="MEUSE24">
        <span class="glitch" data-text="MEUSE24">MEUSE24</span>
      </div>

      <!-- Tagline -->
      <div class="tagline line-6">
        <span data-key="hero_tagline">Developer // Austria // Code Architect</span>
      </div>

      <!-- CTA prompt -->
      <a href="#projects" class="prompt-cta line-7" aria-label="Explore projects">
        <span class="glow-cyan typing-cursor" data-key="hero_prompt">&gt; explore projects</span>
      </a>
    </div>
  </div>
</section>

<style>
  .terminal-hero {
    width: 100%;
    max-width: 700px;
    border: 1px solid var(--color-border-bright);
    background: var(--color-surface);
    overflow: hidden;
  }

  .terminal-titlebar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0.5rem 1rem;
    border-bottom: 1px solid var(--color-border-bright);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.05em;
  }

  .terminal-dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
  }

  .dot-red { background: #ff5f57; }
  .dot-amber { background: #ffbd2e; }
  .dot-green { background: #28c840; }

  .terminal-body {
    padding: 1.5rem;
    font-size: 0.85rem;
    line-height: 1.8;
  }

  @media (min-width: 640px) {
    .terminal-body {
      padding: 2rem;
      font-size: 0.9rem;
    }
  }

  /* Boot lines */
  .boot-line {
    display: flex;
    justify-content: space-between;
    align-items: center;
    opacity: 0;
    animation: fade-in 0.4s ease forwards;
  }

  .boot-ok {
    font-weight: 700;
  }

  .line-1 { animation-delay: 0.2s; }
  .line-2 { animation-delay: 0.6s; }
  .line-3 { animation-delay: 1.0s; }
  .line-4 { animation-delay: 1.4s; }
  .line-5 { animation-delay: 1.9s; }
  .line-6 { animation-delay: 2.4s; }
  .line-7 { animation-delay: 2.8s; }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(4px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Glitch Title */
  .hero-title {
    margin: 1.5rem 0;
    opacity: 0;
    animation: fade-in 0.6s ease forwards;
    text-align: center;
  }

  .glitch {
    font-size: clamp(2.5rem, 10vw, 5rem);
    font-weight: 700;
    color: var(--color-neon-cyan);
    letter-spacing: 0.08em;
    position: relative;
    display: inline-block;
    text-shadow:
      0 0 10px rgba(0, 255, 245, 0.5),
      0 0 40px rgba(0, 255, 245, 0.2);
  }

  .glitch::before,
  .glitch::after {
    content: attr(data-text);
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .glitch::before {
    color: var(--color-neon-magenta);
    text-shadow: none;
    clip-path: inset(0 0 65% 0);
    animation: glitch-top 3s steps(1) infinite;
  }

  .glitch::after {
    color: var(--color-terminal-green);
    text-shadow: none;
    clip-path: inset(60% 0 0 0);
    animation: glitch-bottom 3.5s steps(1) infinite;
  }

  @keyframes glitch-top {
    0%, 100% { transform: translate(0); }
    2%  { transform: translate(2px, -1px); }
    4%  { transform: translate(-2px, 1px); }
    6%  { transform: translate(0); }
    42% { transform: translate(0); }
    44% { transform: translate(-3px, -1px); }
    46% { transform: translate(0); }
  }

  @keyframes glitch-bottom {
    0%, 100% { transform: translate(0); }
    18% { transform: translate(0); }
    20% { transform: translate(3px, 1px); }
    22% { transform: translate(-1px, -1px); }
    24% { transform: translate(0); }
    62% { transform: translate(0); }
    64% { transform: translate(2px, 0); }
    66% { transform: translate(0); }
  }

  /* Tagline */
  .tagline {
    color: var(--color-text-dim);
    font-size: 0.85rem;
    margin: 1rem 0;
    letter-spacing: 0.1em;
    opacity: 0;
    animation: fade-in 0.5s ease forwards;
  }

  /* CTA prompt */
  .prompt-cta {
    display: inline-block;
    margin-top: 1rem;
    text-decoration: none;
    font-size: 0.9rem;
    padding: 0.5rem 0;
    opacity: 0;
    animation: fade-in 0.5s ease forwards;
    transition: opacity 0.2s ease;
  }

  .prompt-cta:hover {
    opacity: 0.8;
  }

  .prompt-cta:focus-visible {
    outline: 1px solid var(--color-neon-cyan);
    outline-offset: 4px;
  }

  /* Glow pulse on the terminal border */
  .terminal-hero {
    box-shadow: 0 0 30px rgba(0, 255, 245, 0.05);
    transition: box-shadow 0.3s ease;
  }

  .terminal-hero:hover {
    box-shadow: 0 0 40px rgba(0, 255, 245, 0.1), 0 0 80px rgba(0, 255, 245, 0.03);
  }
</style>
